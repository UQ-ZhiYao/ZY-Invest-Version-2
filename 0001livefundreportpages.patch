+      var d=s.v.map(function(v,i){return (i?'L':'M')+px(i).toFixed(1)+','+py(v).toFixed(1);}).join('');
+      var area=d+' L'+px(n-1).toFixed(1)+','+(H-padY)+' L'+px(0).toFixed(1)+','+(H-padY)+'Z';
