+    tip.innerHTML='<div style="font-size:.72rem;font-weight:600;color:#1565C0;margin-bottom:3px">'+lbl+'</div><div style="font-size:.85rem;font-weight:400;color:#0F172A">RM '+v.toFixed(4)+'</div>';
