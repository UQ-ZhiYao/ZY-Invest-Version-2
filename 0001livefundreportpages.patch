+    }
+
+    if(results[2].status === 'fulfilled') FUND_OVERVIEW = results[2].value;
+    else console.warn('Fund overview load failed:', results[2].reason && results[2].reason.message);
+
+    if(results[3].status === 'fulfilled') PRODUCT_TYPES = results[3].value;
+    else console.warn('Product types load failed:', results[3].reason && results[3].reason.message);
