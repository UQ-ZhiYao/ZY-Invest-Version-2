+        +'<path d="'+area+'" fill="url(#lg'+s.id+')"/>'
+        +'<path d="'+d+'" fill="none" stroke="'+s.color+'" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>'+dots;
+    }).join('');
+    var ticks=[];
+    for(var tv=mn; tv<=mx+scale.step*0.001; tv+=scale.step){ ticks.push(tv); }
