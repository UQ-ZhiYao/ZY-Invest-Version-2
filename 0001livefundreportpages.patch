+// pgFinancialResults()'s tab buttons call the member portal's global
+// renderMain(instant) (normally defined by pages-subscribe-redeem.js, which
+// this standalone report page does not load). This page only ever shows one
+// "page", so a minimal local re-render is enough to make tab-switching work
+// without pulling in the full member-portal page-router.
+function renderMain(instant){
+  var m=document.getElementById('frMain');
+  if(!m) return;
+  var go=function(){
+    try{ m.innerHTML=pgFinancialResults(); }
+    catch(e){ m.innerHTML='<div style="padding:28px;color:#DC2626"><b>Render error:</b> '+e.message+'</div>'; }
+  };
+  if(instant){ go(); } else { go(); }
+}
+
+// pgFinancialResults()'s chart hover tooltips call frTip/getTip/frHide,
+// now provided by the shared assets/js/portal/admin-portal-shim.js
+// (consolidated there since factsheet.html and fund-overview.html need the
+// exact same functions — see that file for the source-of-truth copy).
+
+// Page init (waits for live Supabase data)
+loadLiveData().then(function(){
+  return Promise.allSettled([
+    (typeof mpLoadIncomeStatement==='function') ? mpLoadIncomeStatement() : Promise.resolve([]),
+    (typeof mpLoadBalanceSheet==='function') ? mpLoadBalanceSheet() : Promise.resolve([])
+  ]);
+}).then(function(results){
+  if(results[0].status==='fulfilled'){ INCOME_STATEMENT = results[0].value || []; INCOME_STATEMENT_ERROR = null; }
+  else { INCOME_STATEMENT = []; INCOME_STATEMENT_ERROR = (results[0].reason && results[0].reason.message) || 'Unknown error'; console.warn('Income statement load failed:', INCOME_STATEMENT_ERROR); }
+
+  if(results[1].status==='fulfilled'){ BALANCE_SHEET = results[1].value || []; BALANCE_SHEET_ERROR = null; }
+  else { BALANCE_SHEET = []; BALANCE_SHEET_ERROR = (results[1].reason && results[1].reason.message) || 'Unknown error'; console.warn('Balance sheet load failed:', BALANCE_SHEET_ERROR); }
+
+  // Cash Flow and Ratio Analysis are both derived from the two statements
+  // above, so they run after them — but don't depend on each other, so
+  // they load in parallel.
+  return Promise.allSettled([
+    (typeof mpLoadCashFlow==='function') ? mpLoadCashFlow(INCOME_STATEMENT, BALANCE_SHEET) : Promise.resolve([]),
+    (typeof mpLoadRatioAnalysis==='function') ? mpLoadRatioAnalysis(INCOME_STATEMENT, BALANCE_SHEET) : Promise.resolve([])
+  ]);
+}).then(function(results){
+  if(results[0].status==='fulfilled'){ CASH_FLOW = results[0].value || []; CASH_FLOW_ERROR = null; }
+  else { CASH_FLOW = []; CASH_FLOW_ERROR = (results[0].reason && results[0].reason.message) || 'Unknown error'; console.warn('Cash flow load failed:', CASH_FLOW_ERROR); }
+
+  if(results[1].status==='fulfilled'){ RATIO_ANALYSIS = results[1].value || []; RATIO_ANALYSIS_ERROR = null; }
+  else { RATIO_ANALYSIS = []; RATIO_ANALYSIS_ERROR = (results[1].reason && results[1].reason.message) || 'Unknown error'; console.warn('Ratio analysis load failed:', RATIO_ANALYSIS_ERROR); }
+}).finally(function(){
+  document.getElementById('frMain').innerHTML=pgFinancialResults();
+  renderNotifs();
+});
+</script>
 </body>
