+      var la=sweep>Math.PI?1:0;
+      var d='M'+x1+' '+y1+' A'+R+' '+R+' 0 '+la+' 1 '+x2+' '+y2+' L'+x3+' '+y3+' A'+ir+' '+ir+' 0 '+la+' 0 '+x4+' '+y4+'Z';
+      paths+='<path d="'+d+'" fill="'+sg.color+'" stroke="none"/>';
