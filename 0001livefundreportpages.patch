+  });
+  DISTS.forEach(function(d){
+    if(d.amt>0){
+      items.push({
+        type: 'Distribution',
+        ref:  (d.fy||'')+(d.type?(' '+d.type):''),
+        date: d.pay!=='—' ? d.pay : d.ex,
+        dateRaw: d.payRaw || d.exRaw,
