+  }).join('');
+  var hoverLine='<line id="nthHoverLine" x1="0" y1="'+padYT+'" x2="0" y2="'+(H-padYB)+'" stroke="#94A3B8" stroke-width="1" stroke-dasharray="3,3" style="display:none;pointer-events:none"/>';
+  window._nthRows=rows;
+  window._nthGranMode='daily';
